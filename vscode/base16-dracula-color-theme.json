  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#00f769",
    "type": "#00f769",
    "class": "#00f769",
    "interface": "#00f769",
    "enum": "#00f769",
    "typeParameter": "#00f769",
    "function": "#62d6e8",
    "method": "#62d6e8",
    "property": "#ea51b2",
    "variable": "#e9e9f4",
    "parameter": "#e9e9f4",
    "variable.defaultLibrary": "#98d1ce",
    "function.defaultLibrary": "#98d1ce",
    "type.defaultLibrary": "#98d1ce",
    "class.defaultLibrary": "#98d1ce",
    "interface.defaultLibrary": "#98d1ce",
    "enum.defaultLibrary": "#98d1ce",
    "property.readonly": "#b45bcf",
    "class:javascriptreact": "#00f769",
    "class:typescriptreact": "#00f769",
    "function:javascriptreact": "#62d6e8",
    "function:typescriptreact": "#62d6e8",
    "property:javascriptreact": "#ea51b2",
    "property:typescriptreact": "#ea51b2",
    "*.declaration:javascriptreact": "#62d6e8",
    "*.declaration:typescriptreact": "#62d6e8",
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "punctuation.definition.string"],
      "settings": {
        "foreground": "#ebff87"
      }
    },
    {
      "scope": ["constant.numeric", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#b45bcf"
      }
    },
    {
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#b45bcf",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "scope": ["entity.name.type", "support.type", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#00f769"
      }
    },
    {
      "scope": ["variable", "entity.name.variable"],
      "settings": {
        "foreground": "#e9e9f4"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "meta.object-literal.key string.quoted",
        "support.type.property",
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#ea51b2"
      }
    },
    {
      "name": "JSX / React — custom components",
      "scope": [
        "support.class.component",
        "support.class.component.jsx",
        "support.class.component.tsx",
        "entity.name.tag.support.class.component",
        "entity.name.tag.support.class.component.jsx",
        "entity.name.tag.support.class.component.tsx",
        "support.class.component.open.jsx",
        "support.class.component.close.jsx",
        "support.class.component.open.tsx",
        "support.class.component.close.tsx"
      ],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "name": "JSX / React — intrinsic HTML tags",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.jsx",
        "entity.name.tag.tsx",
        "entity.name.tag.open.jsx",
        "entity.name.tag.close.jsx",
        "entity.name.tag.open.tsx",
        "entity.name.tag.close.tsx"
      ],
      "settings": {
        "foreground": "#b45bcf"
      }
    },
    {
      "name": "JSX / React — attributes",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.jsx",
        "entity.other.attribute-name.tsx",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#00f769"
      }
    },
    {
      "name": "JSX / React — tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end",
        "punctuation.definition.tag.jsx",
        "punctuation.definition.tag.tsx",
        "meta.tag.jsx punctuation",
        "meta.tag.tsx punctuation"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "JSX / React — embedded expressions",
      "scope": [
        "punctuation.section.embedded",
        "punctuation.section.embedded.begin.jsx",
        "punctuation.section.embedded.end.jsx",
        "punctuation.section.embedded.begin.tsx",
        "punctuation.section.embedded.end.tsx",
        "meta.embedded.expression punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "name": "HTML — tags",
      "scope": [
        "text.html.basic entity.name.tag.html",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#b45bcf"
      }
    },
    {
      "name": "HTML — attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#00f769"
      }
    },
    {
      "name": "HTML — tag punctuation",
      "scope": [
        "text.html.basic punctuation.definition.tag.begin.html",
        "text.html.basic punctuation.definition.tag.end.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "HTML — attribute values",
      "scope": [
        "text.html.basic string.quoted.double.html",
        "text.html.basic string.quoted.single.html",
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#ebff87"
      }
    },
    {
      "name": "JSON / JSONC — keys",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json string.quoted.double",
        "meta.structure.dictionary.key.json string.quoted.single",
        "string.quoted.double.json punctuation.support.type.property-name.begin",
        "string.quoted.double.json punctuation.support.type.property-name.end"
      ],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "name": "JSON / JSONC — language constants",
      "scope": [
        "constant.language.json",
        "constant.language.jsonc"
      ],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "name": "Markdown — heading text",
      "scope": [
        "text.html.markdown entity.name.section.markdown",
        "text.html.markdown heading.1.markdown",
        "text.html.markdown heading.2.markdown",
        "text.html.markdown heading.3.markdown",
        "text.html.markdown heading.4.markdown",
        "text.html.markdown heading.5.markdown",
        "text.html.markdown heading.6.markdown",
        "entity.name.section.markdown",
        "heading.1.markdown",
        "heading.2.markdown",
        "heading.3.markdown",
        "heading.4.markdown",
        "heading.5.markdown",
        "heading.6.markdown",
        "markup.heading.setext.1.markdown",
        "markup.heading.setext.2.markdown"
      ],
      "settings": {
        "foreground": "#00f769",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — heading markers",
      "scope": [
        "text.html.markdown punctuation.definition.heading.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "Markdown — bold",
      "scope": [
        "text.html.markdown markup.bold.markdown",
        "text.html.markdown punctuation.definition.bold.markdown",
        "markup.bold.markdown",
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#ea51b2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — italic",
      "scope": [
        "text.html.markdown markup.italic.markdown",
        "text.html.markdown punctuation.definition.italic.markdown",
        "markup.italic.markdown",
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#e9e9f4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — links",
      "scope": [
        "text.html.markdown string.other.link.description.markdown",
        "text.html.markdown string.other.link.title.markdown",
        "text.html.markdown markup.underline.link.markdown",
        "text.html.markdown constant.other.reference.link.markdown",
        "string.other.link.description.markdown",
        "string.other.link.title.markdown",
        "markup.underline.link.markdown",
        "constant.other.reference.link.markdown",
        "meta.link.inline.markdown"
      ],
      "settings": {
        "foreground": "#ea51b2",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown — link punctuation",
      "scope": [
        "text.html.markdown punctuation.definition.link.markdown",
        "text.html.markdown punctuation.definition.link.title.begin.markdown",
        "text.html.markdown punctuation.definition.link.title.end.markdown",
        "punctuation.definition.link.markdown",
        "punctuation.definition.link.title.begin.markdown",
        "punctuation.definition.link.title.end.markdown"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "Markdown — inline code",
      "scope": [
        "text.html.markdown markup.inline.raw.string.markdown",
        "text.html.markdown punctuation.definition.raw.markdown",
        "markup.inline.raw.string.markdown",
        "punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "#a1efe4"
      }
    },
    {
      "name": "Markdown — fenced code delimiters",
      "scope": [
        "text.html.markdown markup.fenced_code.block.markdown",
        "text.html.markdown fenced_code.block.language.markdown",
        "markup.fenced_code.block.markdown",
        "fenced_code.block.language.markdown"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "Markdown — blockquote",
      "scope": [
        "text.html.markdown markup.quote.markdown",
        "text.html.markdown punctuation.definition.quote.begin.markdown",
        "markup.quote.markdown",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#98d1ce",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — list markers",
      "scope": [
        "text.html.markdown punctuation.definition.list.begin.markdown",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#626483"
      }
    },
    {
      "name": "CSS — selectors (elements)",
      "scope": [
        "entity.name.tag.css",
        "entity.name.tag.custom.css"
      ],
      "settings": {
        "foreground": "#b45bcf"
      }
    },
    {
      "name": "CSS — class and id selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "name": "CSS — properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name.css"
      ],
      "settings": {
        "foreground": "#ea51b2"
      }
    },
    {
      "name": "CSS — property values and units",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.font-name.css",
        "keyword.other.unit.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#ebff87"
      }
    },
    {
      "name": "CSS — at-rules",
      "scope": [
        "keyword.control.at-rule.css",
        "keyword.control.at-rule.import.css",
        "keyword.control.at-rule.media.css"
      ],
      "settings": {
        "foreground": "#b45bcf",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python — decorators",
      "scope": [
        "entity.name.function.decorator.python",
        "meta.function.decorator.python entity.name.function",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "name": "Python — self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.parameter.function.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#ea51b2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python — builtins and constants",
      "scope": [
        "constant.language.python",
        "support.function.builtin.python",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "name": "Python — f-string expression braces",
      "scope": [
        "constant.character.format.placeholder.other.python",
        "meta.fstring.python punctuation.definition.expression"
      ],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "name": "YAML keys (distinguish from string values)",
      "scope": [
        "meta.mapping.key",
        "meta.mapping.key.yaml",
        "meta.map.key",
        "meta.map.key.yaml",
        "entity.name.tag.yaml",
        "entity.name.tag.yaml string.unquoted",
        "entity.name.tag.yaml string.unquoted.plain.out.yaml",
        "meta.mapping.key.yaml string.unquoted.plain.out.yaml",
        "meta.mapping.key.yaml string.quoted",
        "meta.mapping.key.yaml string.quoted.double",
        "meta.mapping.key.yaml string.quoted.single"
      ],
      "settings": {
        "foreground": "#62d6e8"
      }
    },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded.begin",
        "punctuation.section.embedded.end"
      ],
      "settings": {
        "foreground": "#98d1ce"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#f7f7fb",
        "background": "#ea51b2"
      }
    }
  ]
}
